# Get your token from @BotFather in Telegram
BOT_TOKEN=your-telegram-bot-token-here

# OpenAI API key for generating personalized greetings
OPENAI_API_KEY=your-openai-api-key-here

# Port for the web API (used by Telegram Mini App)
WEB_PORT=8080

# Path for persistent data storage (set to Railway volume mount path in production)
# DATA_DIR=/data
